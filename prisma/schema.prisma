generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(uuid())
  name        String?
  email       String       @unique
  password    String
  role        Role         @default(USER)
  businessOwnerId String?
  businessAccessRole BusinessAccessRole?
  accountStatus UserAccountStatus @default(ACTIVE)
  statusReason String?
  statusUpdatedAt DateTime?
  kycStatus   KycStatus    @default(PENDING)
  kycNotes    String?
  kycVerifiedAt DateTime?
  level       UserLevel    @default(L1)
  balance     Float        @default(0)
  dailySubmits Int         @default(0)
  totalApproved Int        @default(0)
  totalRejected Int        @default(0)
  emergencyWithdrawCount Int @default(0)
  monthlyEmergencyWithdrawCount Int @default(0)
  emergencyWithdrawMonthKey String?
  lastLevelResetAt DateTime @default(now())
  createdAt   DateTime     @default(now())
  ipAddress   String?
  isSuspicious Boolean     @default(false)
  suspiciousReason String?
  flaggedAt   DateTime?
  submissions Submission[]
  campaigns   Campaign[]   @relation("BusinessCampaignsV2")
  businessOwner User?      @relation("BusinessTeam", fields: [businessOwnerId], references: [id])
  teamMembers  User[]      @relation("BusinessTeam")
  transactions WalletTransaction[]
  withdrawals Withdrawal[]
  withdrawRequests WithdrawRequest[]
  notifications Notification[]
  notificationDeliveryLogs NotificationDeliveryLog[]
  paymentOrders PaymentOrder[]
  businessWallet BusinessWallet?
  kycRequests BusinessKycRequest[]
  twoFactorEnabled Boolean @default(false)
  twoFactorEnabledAt DateTime?
  requestedWalletAdjustments WalletAdjustmentRequest[] @relation("WalletAdjustmentRequester")
  targetWalletAdjustments WalletAdjustmentRequest[] @relation("WalletAdjustmentTarget")
  reviewedWalletAdjustments WalletAdjustmentRequest[] @relation("WalletAdjustmentReviewer")
  adminTwoFactorChallenges AdminTwoFactorChallenge[]
  adminTwoFactorRecoveryCodes AdminTwoFactorRecoveryCode[]
  deletedAt DateTime?
  deletedByUserId String?
  deletionReason String?
}

model BusinessKycRequest {
  id            String     @id @default(uuid())
  businessId    String
  business      User       @relation(fields: [businessId], references: [id])
  legalName     String
  contactName   String
  phone         String
  address       String
  website       String?
  taxId         String?
  documentUrl   String?
  status        KycStatus  @default(PENDING)
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  reviewedAt    DateTime?
  reviewedByUserId String?
}

model Submission {
  id        String           @id @default(uuid())
  proof     String
  proofLink String?
  proofText String?
  ipAddress String?
  status    SubmissionStatus @default(PENDING)
  managerStatus SubmissionStatus @default(PENDING)
  adminStatus SubmissionStatus @default(PENDING)
  managerEscalatedAt DateTime?
  managerEscalationReason String?
  managerEscalatedByUserId String?
  rewardAmount Float @default(0)
  createdAt DateTime         @default(now())
  userId    String
  campaignId String?
  campaign  Campaign?        @relation(fields: [campaignId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
}

model Withdrawal {
  id        String           @id @default(uuid())
  amount    Float
  upiId     String?
  upiName   String?
  isEmergency Boolean       @default(false)
  status    WithdrawalStatus @default(PENDING)
  adminNote String?
  processedAt DateTime?
  createdAt DateTime         @default(now())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
}

model WalletTransaction {
  id        String          @id @default(uuid())
  userId    String
  amount    Float
  type      TransactionType
  note      String?
  createdAt DateTime        @default(now())
  walletAdjustmentRequest WalletAdjustmentRequest?

  user      User            @relation(fields: [userId], references: [id])
}

model WalletAdjustmentRequest {
  id                 String                 @id @default(uuid())
  targetUserId       String
  requestedByUserId  String
  reviewedByUserId   String?
  amount             Float
  type               TransactionType
  reason             String
  reviewNote         String?
  status             WalletAdjustmentStatus @default(PENDING)
  walletTransactionId String?               @unique
  createdAt          DateTime               @default(now())
  reviewedAt         DateTime?

  targetUser         User                   @relation("WalletAdjustmentTarget", fields: [targetUserId], references: [id])
  requestedByUser    User                   @relation("WalletAdjustmentRequester", fields: [requestedByUserId], references: [id])
  reviewedByUser     User?                  @relation("WalletAdjustmentReviewer", fields: [reviewedByUserId], references: [id])
  walletTransaction  WalletTransaction?     @relation(fields: [walletTransactionId], references: [id])
}

model PlatformEarning {
  id        String   @id @default(uuid())
  amount    Float
  source    String?
  createdAt DateTime @default(now())
}

model PlatformTreasury {
  id        String   @id @default("main")
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformPayout {
  id          String               @id @default(uuid())
  amount      Float
  note        String?
  status      PlatformPayoutStatus @default(PENDING)
  createdAt   DateTime             @default(now())
  processedAt DateTime?
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  actorRole   String?
  targetUserId String?
  action      String
  details     String?
  beforeState Json?
  afterState  Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model Campaign {
  id              String                @id @default(cuid())
  businessId      String
  business        User                  @relation("BusinessCampaignsV2", fields: [businessId], references: [id])
  title           String
  description     String
  category        String
  taskLink        String?
  rewardPerTask   Float
  totalBudget     Float
  remainingBudget Float
  status          CampaignStatus        @default(PENDING)
  escalatedAt     DateTime?
  escalationReason String?
  createdAt       DateTime              @default(now())
  submissions     Submission[]
  instructions    CampaignInstruction[]
}

model CampaignInstruction {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id])
  instructionText String
  sequence        Int
}

model WithdrawRequest {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  amount    Float
  upiId     String
  status    WithdrawStatus @default(PENDING)
  createdAt DateTime       @default(now())
}

model PaymentOrder {
  id                String             @id @default(uuid())
  userId            String
  provider          String             @default("RAZORPAY")
  providerOrderId   String?            @unique
  providerPaymentId String?            @unique
  amount            Float
  currency          String             @default("INR")
  status            PaymentOrderStatus @default(CREATED)
  receipt           String             @unique
  metadata          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  paidAt            DateTime?

  user              User               @relation(fields: [userId], references: [id])
}

model BusinessWallet {
  id          String @id @default(cuid())
  businessId  String @unique
  business    User   @relation(fields: [businessId], references: [id])
  balance     Float  @default(0)
  totalFunded Float  @default(0)
  totalSpent  Float  @default(0)
  totalRefund Float  @default(0)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  details   String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id])
  deliveryLogs NotificationDeliveryLog[]
}

model CmsContent {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(true)
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  message   String
  link      String?
  isActive  Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IpAccessRule {
  id        String     @id @default(uuid())
  ip        String     @unique
  type      IpRuleType @default(BLOCK)
  note      String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  expiresAt DateTime?
}

model SecurityEvent {
  id          String               @id @default(uuid())
  kind        String
  severity    SecurityEventSeverity @default(LOW)
  status      SecurityEventStatus  @default(OPEN)
  ipAddress   String?
  userId      String?
  message     String
  metadata    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  resolvedAt  DateTime?
  resolvedByUserId String?
}

model AdminTwoFactorChallenge {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String?
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  consumedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AdminTwoFactorRecoveryCode {
  id        String   @id @default(uuid())
  userId    String
  codeHash  String
  createdAt DateTime @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id])
}

model NotificationTemplate {
  id        String          @id @default(uuid())
  key       String          @unique
  name      String
  channel   DeliveryChannel @default(IN_APP)
  subject   String?
  body      String
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model NotificationDeliveryLog {
  id             String          @id @default(uuid())
  userId         String
  notificationId String?
  templateKey    String?
  channel        DeliveryChannel
  status         DeliveryStatus  @default(SENT)
  error          String?
  payload        Json?
  createdAt      DateTime        @default(now())

  user         User          @relation(fields: [userId], references: [id])
  notification Notification? @relation(fields: [notificationId], references: [id])
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model LegalEvidence {
  id               String   @id @default(uuid())
  entityType       String
  entityId         String
  submittedByUserId String?
  note             String?
  fileUrl          String?
  metadata         Json?
  createdAt        DateTime @default(now())
}

enum Role {
  USER
  BUSINESS
  MANAGER
  ADMIN
}

enum BusinessAccessRole {
  OWNER
  EDITOR
  VIEWER
}

enum UserAccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum UserLevel {
  L1
  L2
  L3
  L4
  L5
}

enum CampaignStatus {
  PENDING
  APPROVED
  REJECTED
  LIVE
  COMPLETED
}

enum SubmissionStatus {
  PENDING
  MANAGER_APPROVED
  MANAGER_REJECTED
  ADMIN_APPROVED
  ADMIN_REJECTED
  APPROVED
  REJECTED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum WalletAdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
}

enum PlatformPayoutStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentOrderStatus {
  CREATED
  PAID
  FAILED
}

enum IpRuleType {
  BLOCK
  ALLOW
}

enum SecurityEventSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SecurityEventStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum DeliveryChannel {
  IN_APP
  EMAIL
}

enum DeliveryStatus {
  SENT
  FAILED
  SKIPPED
}
