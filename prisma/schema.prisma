generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(uuid())
  name        String?
  email       String       @unique
  password    String
  role        Role         @default(USER)
  level       UserLevel    @default(L1)
  balance     Float        @default(0)
  dailySubmits Int         @default(0)
  totalApproved Int        @default(0)
  totalRejected Int        @default(0)
  emergencyWithdrawCount Int @default(0)
  lastLevelResetAt DateTime @default(now())
  createdAt   DateTime     @default(now())
  ipAddress   String?
  isSuspicious Boolean     @default(false)
  suspiciousReason String?
  flaggedAt   DateTime?
  submissions Submission[]
  campaigns   Campaign[]   @relation("BusinessCampaignsV2")
  transactions WalletTransaction[]
  withdrawals Withdrawal[]
  withdrawRequests WithdrawRequest[]
  notifications Notification[]
  paymentOrders PaymentOrder[]
  businessWallet BusinessWallet?
}

model Submission {
  id        String           @id @default(uuid())
  proof     String
  proofLink String?
  proofText String?
  ipAddress String?
  status    SubmissionStatus @default(PENDING)
  managerStatus SubmissionStatus @default(PENDING)
  adminStatus SubmissionStatus @default(PENDING)
  rewardAmount Float @default(0)
  createdAt DateTime         @default(now())
  userId    String
  campaignId String?
  campaign  Campaign?        @relation(fields: [campaignId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
}

model Withdrawal {
  id        String           @id @default(uuid())
  amount    Float
  upiId     String?
  upiName   String?
  status    WithdrawalStatus @default(PENDING)
  createdAt DateTime         @default(now())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
}

model WalletTransaction {
  id        String          @id @default(uuid())
  userId    String
  amount    Float
  type      TransactionType
  note      String?
  createdAt DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id])
}

model PlatformEarning {
  id        String   @id @default(uuid())
  amount    Float
  source    String?
  createdAt DateTime @default(now())
}

model PlatformTreasury {
  id        String   @id @default("main")
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformPayout {
  id          String               @id @default(uuid())
  amount      Float
  note        String?
  status      PlatformPayoutStatus @default(PENDING)
  createdAt   DateTime             @default(now())
  processedAt DateTime?
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  actorRole   String?
  targetUserId String?
  action      String
  details     String?
  createdAt   DateTime @default(now())
}

model Campaign {
  id              String                @id @default(cuid())
  businessId      String
  business        User                  @relation("BusinessCampaignsV2", fields: [businessId], references: [id])
  title           String
  description     String
  category        String
  taskLink        String?
  rewardPerTask   Float
  totalBudget     Float
  remainingBudget Float
  status          CampaignStatus        @default(PENDING)
  createdAt       DateTime              @default(now())
  submissions     Submission[]
  instructions    CampaignInstruction[]
}

model CampaignInstruction {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id])
  instructionText String
  sequence        Int
}

model WithdrawRequest {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  amount    Float
  upiId     String
  status    WithdrawStatus @default(PENDING)
  createdAt DateTime       @default(now())
}

model PaymentOrder {
  id                String             @id @default(uuid())
  userId            String
  provider          String             @default("RAZORPAY")
  providerOrderId   String?            @unique
  providerPaymentId String?            @unique
  amount            Float
  currency          String             @default("INR")
  status            PaymentOrderStatus @default(CREATED)
  receipt           String             @unique
  metadata          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  paidAt            DateTime?

  user              User               @relation(fields: [userId], references: [id])
}

model BusinessWallet {
  id          String @id @default(cuid())
  businessId  String @unique
  business    User   @relation(fields: [businessId], references: [id])
  balance     Float  @default(0)
  totalFunded Float  @default(0)
  totalSpent  Float  @default(0)
  totalRefund Float  @default(0)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  details   String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  BUSINESS
  MANAGER
  ADMIN
}

enum UserLevel {
  L1
  L2
  L3
  L4
  L5
}

enum CampaignStatus {
  PENDING
  APPROVED
  REJECTED
  LIVE
  COMPLETED
}

enum SubmissionStatus {
  PENDING
  MANAGER_APPROVED
  MANAGER_REJECTED
  ADMIN_APPROVED
  ADMIN_REJECTED
  APPROVED
  REJECTED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
}

enum PlatformPayoutStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentOrderStatus {
  CREATED
  PAID
  FAILED
}
